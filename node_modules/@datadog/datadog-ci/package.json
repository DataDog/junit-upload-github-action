{
  "name": "@datadog/datadog-ci",
  "version": "5.11.0",
  "description": "Use Datadog from your CI.",
  "license": "Apache-2.0",
  "keywords": [
    "datadog",
    "datadog-ci"
  ],
  "homepage": "https://github.com/DataDog/datadog-ci",
  "repository": {
    "type": "git",
    "url": "https://github.com/DataDog/datadog-ci.git",
    "directory": "packages/datadog-ci"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": "dist/cli.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn package:clean; yarn package:build",
    "bundle": "node scripts/esbuild.mjs",
    "lint": "yarn package:lint",
    "prepack": "yarn package:clean-dist"
  },
  "dependencies": {
    "@datadog/datadog-ci-base": "5.11.0",
    "@datadog/datadog-ci-plugin-coverage": "5.11.0",
    "@datadog/datadog-ci-plugin-deployment": "5.11.0",
    "@datadog/datadog-ci-plugin-dora": "5.11.0",
    "@datadog/datadog-ci-plugin-gate": "5.11.0",
    "@datadog/datadog-ci-plugin-junit": "5.11.0",
    "@datadog/datadog-ci-plugin-sarif": "5.11.0",
    "@datadog/datadog-ci-plugin-sbom": "5.11.0",
    "clipanion": "3.2.1",
    "typanion": "3.14.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.3",
    "chalk": "3.0.0",
    "esbuild": "0.25.9"
  }
}